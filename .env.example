# Google Apps Script Web App URL
# Deploy your Apps Script sebagai web app dan paste URL-nya di sini
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Password admin (simpan di Vercel environment variables)
ADMIN_PASSWORD=admin123

# Secret key untuk JWT session (generate random string panjang)
AUTH_SECRET=your-super-secret-key-min-32-chars-long

# URL production aplikasi
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
